# Banco de dados (PostgreSQL)
# Exemplo local: postgresql://postgres:senha@localhost:5432/snap_fisk?schema=public
# Exemplo Neon: postgresql://usuario:senha@ep-xxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/snap_fisk?schema=public"

# Autenticação JWT
# Troque por uma string longa e aleatória em produção
JWT_SECRET="troque-por-uma-chave-secreta-longa"

# Porta do servidor
PORT=3000
