generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FiscalRule {
  id             String   @id @default(uuid())
  originUf       String?
  destinationUf  String?
  operation      String?
  purpose        String?
  taxRegime      String?
  active         Boolean  @default(true)
  priority       Int      @default(0)
  cfop           String
  cstCsosn       String
  icmsApplicable Boolean
  ipiApplicable  Boolean
  observation    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  guidedIssuances GuidedIssuance[]

  @@index([active, originUf, destinationUf, operation, purpose, taxRegime])
  @@map("fiscal_rules")
}

model GuidedIssuance {
  id             String   @id @default(uuid())
  originUf       String
  destinationUf  String
  operation      String
  purpose        String
  taxRegime      String

  ruleId         String?
  cfop           String?
  cstCsosn       String?
  icmsApplicable Boolean?
  ipiApplicable  Boolean?
  observation    String?

  createdAt      DateTime @default(now())

  rule           FiscalRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([ruleId])
  @@map("guided_issuance")
}
