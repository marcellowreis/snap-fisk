generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USUÁRIO ────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  cnpj         String   @unique
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company?
  subscription Subscription?
  issuances    GuidedIssuance[]
  products     Product[]
  customers    Customer[]
  invoices     Invoice[]
  certificate  Certificate?

  @@map("users")
}

// ─── EMPRESA ────────────────────────────────────────────────────────────────

model Company {
  id           String   @id @default(uuid())
  userId       String   @unique
  razaoSocial  String
  nomeFantasia String?
  cnpj         String
  ie           String?
  im           String?
  uf           String
  cuf          String   @default("35")
  cMun         String   @default("3550308")
  xMun         String   @default("Sao Paulo")
  cep          String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  fone         String?
  email        String?
  taxRegime    String
  serie        String   @default("0")
  proximaNF    Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("companies")
}

// ─── CERTIFICADO DIGITAL ─────────────────────────────────────────────────────

model Certificate {
  id          String   @id @default(uuid())
  userId      String   @unique
  pfxData     String
  password    String
  cnpj        String
  razaoSocial String?
  validUntil  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

// ─── PRODUTOS ────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(uuid())
  userId      String
  codigo      String?
  descricao   String
  ncm         String
  unidade     String   @default("PC")
  valorUnit   Float    @default(0)
  ean         String   @default("SEM GTIN")
  origem      String   @default("0")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]

  @@index([userId])
  @@map("products")
}

// ─── CLIENTES / DESTINATÁRIOS ─────────────────────────────────────────────────

model Customer {
  id          String   @id @default(uuid())
  userId      String
  tipoPessoa  String   @default("PF")
  cpfCnpj     String
  nome        String
  ie          String?
  indIEDest   String   @default("9")
  email       String?
  fone        String?
  cep         String?
  logradouro  String?
  numero      String?
  bairro      String?
  xMun        String?
  cMun        String?
  uf          String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices    Invoice[]

  @@index([userId])
  @@index([cpfCnpj])
  @@map("customers")
}

// ─── NOTA FISCAL ─────────────────────────────────────────────────────────────

model Invoice {
  id          String        @id @default(uuid())
  userId      String
  customerId  String?
  numero      Int
  serie       String        @default("0")
  chaveAcesso String?
  tpNF        String        @default("1")
  natOp       String
  cfop        String
  cstCsosn    String
  infCpl      String?
  status      InvoiceStatus @default(RASCUNHO)
  xmlGerado   String?
  ambiente    String        @default("2")
  dhEmi       DateTime      @default(now())
  vTotal      Float         @default(0)
  vFrete      Float         @default(0)
  vDesc       Float         @default(0)
  modFrete    String        @default("9")
  tPag        String        @default("90")
  vPag        Float         @default(0)
  operation   String?
  purpose     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items       InvoiceItem[]

  @@index([userId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  RASCUNHO
  GERADO
  AUTORIZADO
  CANCELADO
  REJEITADO
}

// ─── ITENS DA NOTA FISCAL ────────────────────────────────────────────────────

model InvoiceItem {
  id        String   @id @default(uuid())
  invoiceId String
  productId String?
  nItem     Int
  cProd     String?
  xProd     String
  ncm       String
  cfop      String
  uCom      String   @default("PC")
  qCom      Float    @default(1)
  vUnCom    Float
  vProd     Float
  ean       String   @default("SEM GTIN")
  origem    String   @default("0")
  csosn     String   @default("102")
  createdAt DateTime @default(now())

  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@map("invoice_items")
}

// ─── PLANOS ─────────────────────────────────────────────────────────────────

model Plan {
  id          String   @id @default(uuid())
  code        PlanCode @unique
  name        String
  price       Float
  nfLimit     Int
  description String?
  createdAt   DateTime @default(now())

  subscriptions Subscription[]

  @@map("plans")
}

enum PlanCode {
  SNAP_ONE
  SNAP_TEN
  SNAP_MEI
}

// ─── ASSINATURA ─────────────────────────────────────────────────────────────

model Subscription {
  id        String             @id @default(uuid())
  userId    String             @unique
  planId    String
  status    SubscriptionStatus @default(PENDING)
  nfUsed    Int                @default(0)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      Plan               @relation(fields: [planId], references: [id])
  charges   BillingCharge[]

  @@map("subscriptions")
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELED
}

// ─── COBRANÇA ───────────────────────────────────────────────────────────────

model BillingCharge {
  id             String       @id @default(uuid())
  subscriptionId String
  amount         Float
  status         ChargeStatus @default(PENDING)
  pixCode        String?
  paidAt         DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("billing_charges")
}

enum ChargeStatus {
  PENDING
  PAID
  EXPIRED
  CANCELED
}

// ─── MOTOR FISCAL ───────────────────────────────────────────────────────────

model FiscalRule {
  id                        String   @id @default(uuid())
  originUf                  String?
  destinationUf             String?
  operation                 String?
  purpose                   String?
  taxRegime                 String?
  active                    Boolean  @default(true)
  priority                  Int      @default(0)
  cfop                      String
  cstCsosn                  String
  icmsApplicable            Boolean
  ipiApplicable             Boolean
  observation               String?
  naturezaOperacao          String?
  cfopEntradaVinculado      String?
  geraCredito               Boolean  @default(false)
  temST                     Boolean  @default(false)
  informacoesComplementares String?
  baseLegal                 String?
  mensagemAlerta            String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  guidedIssuances GuidedIssuance[]

  @@index([active, originUf, destinationUf, operation, purpose, taxRegime])
  @@map("fiscal_rules")
}

// ─── HISTÓRICO DE ORIENTAÇÕES ───────────────────────────────────────────────

model GuidedIssuance {
  id                        String   @id @default(uuid())
  userId                    String?
  originUf                  String
  destinationUf             String
  operation                 String
  purpose                   String
  taxRegime                 String
  ruleId                    String?
  cfop                      String?
  cstCsosn                  String?
  icmsApplicable            Boolean?
  ipiApplicable             Boolean?
  observation               String?
  naturezaOperacao          String?
  cfopEntradaVinculado      String?
  geraCredito               Boolean?
  temST                     Boolean?
  informacoesComplementares String?
  baseLegal                 String?
  mensagemAlerta            String?
  createdAt                 DateTime @default(now())

  user User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  rule FiscalRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
  @@index([ruleId])
  @@map("guided_issuance")
}
