model Invoice {
  id          String        @id @default(uuid())
  userId      String
  customerId  String?
  numero      Int
  serie       String        @default("0")
  chaveAcesso String?
  tpNF        String        @default("1")
  natOp       String
  cfop        String
  cstCsosn    String
  infCpl      String?
  status      InvoiceStatus @default(RASCUNHO)
  xmlGerado   String?
  ambiente    String        @default("2")
  dhEmi       DateTime      @default(now())
  vTotal      Float         @default(0)
  vFrete      Float         @default(0)
  vDesc       Float         @default(0)
  modFrete    String        @default("9")
  tPag        String        @default("90")
  vPag        Float         @default(0)
  operation   String?
  purpose     String?
  finNFe      String        @default("1")
  refNFe      String?
  infAdFisco  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items       InvoiceItem[]

  @@index([userId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  RASCUNHO
  GERADO
  AUTORIZADO
  CANCELADO
